* text=auto
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
# Historical ablation sources are immutable byte-for-byte evidence. Preserve
# their original CRLF bytes in Git instead of normalizing them as active YAML.
training_project/models/ablations/source/*.yaml -text -diff
training_project/models/ablations/source/*.yml -text -diff
# B4 is both the historical evidence and the active canonical model.
training_project/models/B4_A-GFPN_RepHFE_target.yaml -text -diff
*.json text eol=lf
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.rknn filter=lfs diff=lfs merge=lfs -text
*.engine filter=lfs diff=lfs merge=lfs -text
